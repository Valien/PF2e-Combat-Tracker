{
  "name": "initiative-tracker",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "A modern, themeable initiative tracker for Pathfinder 2e combat encounters with separate DM and player views",
  "author": "Gabriel Valforte",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Valforte/initiative-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/Valforte/initiative-tracker/issues"
  },
  "homepage": "https://valforte.github.io/Initiative-Tracker/",
  "keywords": [
    "pathfinder",
    "pathfinder-2e",
    "initiative-tracker",
    "combat-tracker",
    "rpg",
    "tabletop",
    "vue3",
    "typescript",
    "dnd",
    "ttrpg"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "vue-tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,ts,vue,css,json}\" \"*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,ts,vue,css,json}\" \"*.{ts,js,json}\"",
    "update-monsters": "node scripts/parse-aon-monsters.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@vueuse/core": "14.0.0",
    "firebase": "^12.5.0",
    "reka-ui": "^2.6.0",
    "tailwindcss": "^4.1.17",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/ui": "^4.0.8",
    "@vue/tsconfig": "^0.7.0",
    "cheerio": "^1.2.0",
    "daisyui": "^5.4.7",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^27.1.0",
    "prettier": "^3.9.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.65.0",
    "vite": "7.2.2",
    "vitest": "^4.0.8",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.1.3",
    "zod": "^4.4.3"
  }
}
